# ─────────────────────────────────────────────
# HOSPICALFA MEDICAL — Variables de Entorno
# Copia este archivo como .env.local y completa
# los valores antes de ejecutar el proyecto.
# ─────────────────────────────────────────────

# NEXT.JS
NEXT_PUBLIC_SITE_URL=https://hospicalfamedical.com
NEXT_PUBLIC_SITE_NAME="Hospicalfa Medical"

# API BACKEND (cuando tengas el backend)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# AUTENTICACIÓN JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# BASE DE DATOS (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/hospicalfa_db"

# CLOUDINARY (subida de imágenes)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# EMAIL (Resend o Nodemailer)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=no-reply@hospicalfamedical.com

# GOOGLE ANALYTICS (opcional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
